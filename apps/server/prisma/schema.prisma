generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  projects     Project[]
  apiKeys      ApiKey[]
  events       Event[]
}

model Project {
  id          String        @id @default(cuid())
  name        String
  domain      String
  description String?
  status      ProjectStatus @default(ACTIVE)
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  apiKeys     ApiKey[]
  events      Event[]
}

model ApiKey {
  id          String       @id @default(cuid())
  name        String
  keyHash     String       @unique
  keyPrefix   String
  maskedKey   String
  permissions String       @default("Ingest Events")
  status      ApiKeyStatus @default(ACTIVE)
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId   String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  events      Event[]
}

model Event {
  id         String   @id @default(cuid())
  name       String
  properties Json     @default("{}")
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  apiKeyId   String
  apiKey     ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([projectId, createdAt(sort: Desc)])
}

enum ProjectStatus {
  ACTIVE
  INACTIVE
}

enum ApiKeyStatus {
  ACTIVE
  REVOKED
}
