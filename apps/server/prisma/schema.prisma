generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  projects     Project[]
  apiKeys      ApiKey[]
  events       Event[]
  alerts       Alert[]
}

model Project {
  id          String        @id @default(cuid())
  name        String
  domain      String
  description String?
  status      ProjectStatus @default(ACTIVE)
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  apiKeys     ApiKey[]
  events      Event[]
  alerts      Alert[]
}

model ApiKey {
  id          String       @id @default(cuid())
  name        String
  keyHash     String       @unique
  keyPrefix   String
  maskedKey   String
  permissions String       @default("Ingest Events")
  status      ApiKeyStatus @default(ACTIVE)
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId   String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  events      Event[]
}

model Event {
  id             String   @id @default(cuid())
  name           String
  properties     Json     @default("{}")
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  apiKeyId       String
  apiKey         ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  // Client-supplied idempotency key (Idempotency-Key header or body field).
  // Null when the caller didn't send one — no dedup applied in that case.
  idempotencyKey String?
  ipAddress      String?
  userAgent      String?

  @@index([userId, createdAt(sort: Desc)])
  @@index([projectId, createdAt(sort: Desc)])
  // Enforces per-API-key idempotency at the DB level (NULLs don't collide,
  // so events without an idempotency key are unaffected).
  @@unique([apiKeyId, idempotencyKey])
}

model Alert {
  id            String         @id @default(cuid())
  name          String
  eventName     String
  threshold     Int
  windowMinutes Int
  status        AlertStatus    @default(ACTIVE)
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId     String
  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  triggers      AlertTrigger[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([projectId])
  @@index([projectId, eventName, status])
}

// A real, saved record of an alert rule reaching its threshold. Created only
// by the ingestion path (see evaluateAlertsForEvent) — never fabricated in
// the UI. eventCount/threshold are snapshots at trigger time so the record
// stays meaningful even if the alert rule is edited later.
model AlertTrigger {
  id         String   @id @default(cuid())
  alertId    String
  alert      Alert    @relation(fields: [alertId], references: [id], onDelete: Cascade)
  eventCount Int
  threshold  Int
  createdAt  DateTime @default(now())

  @@index([alertId, createdAt(sort: Desc)])
}

enum ProjectStatus {
  ACTIVE
  INACTIVE
}

enum AlertStatus {
  ACTIVE
  INACTIVE
}

enum ApiKeyStatus {
  ACTIVE
  REVOKED
}
